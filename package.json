{
  "name": "pharmacy-hive-nestjs",
  "version": "1.2.2",
  "description": "Pharmacy Hive (NestJS) — backend for syncing Jotform submissions to Monday.com boards",
  "author": "Hai Duong",
  "license": "MIT",
  "engines": {
    "node": ">=22.14.0"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug 0.0.0.0:9229 --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "sync:retrigger": "tsx ./src/scripts/retriggerJotformSync.ts",
    "test:jotform-file": "tsx ./src/scripts/downloadJotformUpload.ts"
  },
  "dependencies": {
    "@appsignal/nodejs": "^3.6.6",
    "@bull-board/api": "^6.16.2",
    "@bull-board/express": "^6.16.2",
    "@bull-board/ui": "^6.16.2",
    "@nestjs/bullmq": "^11.0.2",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/sequelize": "^11.0.0",
    "axios": "^1.7.7",
    "bullmq": "^5.53.0",
    "cookie-parser": "^1.4.7",
    "dayjs": "^1.11.13",
    "geoip-lite": "^1.4.10",
    "i18n-iso-countries": "^7.14.0",
    "ioredis": "^5.6.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "libphonenumber-js": "^1.12.9",
    "monday-sdk-js": "^0.5.6",
    "multer": "^2.1.1",
    "mysql2": "^3.6.1",
    "nest-winston": "^1.10.2",
    "randomstring": "^1.3.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sequelize": "^6.33.0",
    "sequelize-typescript": "^2.1.6",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^5.0.0",
    "@types/geoip-lite": "^1.4.4",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.9.2",
    "@types/randomstring": "^1.3.0",
    "@types/validator": "^13.0.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^15.15.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "sequelize-cli": "^6.6.2",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.62.0"
  }
}
